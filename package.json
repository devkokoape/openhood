{
  "name": "openhood",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy:local": "hardhat run scripts/deploy.cjs",
    "contracts:deploy:testnet": "hardhat run scripts/deploy.cjs --network robinhoodTestnet",
    "contracts:smoke:testnet": "hardhat run scripts/smoke-test.cjs --network robinhoodTestnet",
    "contracts:deploy:wait": "node scripts/deploy-when-funded.cjs",
    "opensea:refresh": "node scripts/refresh-opensea-snapshot.cjs",
    "indexer:dev": "npm --prefix server start",
    "indexer:once": "npm --prefix server run sync:once"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.2.0",
    "@tanstack/react-query": "^5.101.2",
    "@wagmi/connectors": "^8.0.22",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7",
    "viem": "^2.55.2",
    "wagmi": "^3.7.1"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@tailwindcss/vite": "^4.3.2",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "chai": "^4.5.0",
    "dotenv": "^17.4.2",
    "ethers": "^6.13.5",
    "hardhat": "^2.22.18",
    "mocha": "^10.8.2",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
