# Optional: OpenSea API key for live events / higher rate limits
# Get one at https://docs.opensea.io/reference/api-keys
VITE_OPENSEA_API_KEY=

# Optional: WalletConnect Cloud project ID (enables WalletConnect QR)
# https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# ── Marketplace contracts (Robinhood testnet) ──
# Deployer private key (NEVER commit real keys). Fund with testnet ETH first.
DEPLOYER_PRIVATE_KEY=
RH_TESTNET_RPC=https://rpc.testnet.chain.robinhood.com
# Optional override for fee collector (defaults to deployer)
FEE_RECIPIENT=

# Frontend (filled by deploy script → deployments/robinhoodTestnet.env)
VITE_MARKETPLACE_ADDRESS=
VITE_DEMO_NFT_ADDRESS=
VITE_CHAIN_ID=46630
